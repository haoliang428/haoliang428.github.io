          title="Value effect of AI innovation zones: Green premium and cost reduction pathways in environmental disclosure"
          authors="Liu M., Zhang W., & Liang H."
          journal="Research in International Business and Finance"
          date="2026"
        />
        <PublicationItem 
          title="Quantifying the Environmental Impact of Electric Vehicle Adoption"
          authors="Liang, H. & Hernke M."
          conference="International Conference on Frontiers of Energy and Environment Engineering (CFEEE)"
