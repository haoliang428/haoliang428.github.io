---
interface Props {
  title: string;
  authors: string;
  journal?: string;
  conference?: string;
  date: string;
  lastItem?: boolean;
}

const { title, authors, journal, conference, date, lastItem } = Astro.props;
---

<div class="flex relative group/pub mb-2 last:mb-0">
  <div class="education__time w-5 shrink-0 flex flex-col items-center relative">
    <div class={`absolute top-0 w-[2px] transition-colors duration-300 h-full ${lastItem ? 'bg-gradient-to-b from-primary/20 via-primary/20 to-transparent' : 'bg-primary/20 group-hover/pub:bg-primary/50'}`}></div>
    <span class="w-4 h-4 bg-primary block rounded-full mt-10 relative z-10 shadow-lg shadow-primary/40 ring-4 ring-primary/20 transition-all duration-300 group-hover/pub:scale-125"></span>
  </div>
  
  <div class="education__data bd-grid px-8 pb-10 w-full transition-all duration-300">
    <div class="glass p-8 rounded-[2rem] border border-white/40 shadow-sm group-hover/pub:shadow-xl group-hover/pub:-translate-y-1 transition-all duration-300">
      <div class="flex flex-col md:flex-row justify-between items-start mb-2 gap-4">
        <div class="flex flex-col flex-1">
          <div class="text-primary font-bold text-sm tracking-wide uppercase mb-1">
            {authors}
          </div>
          <h3 class="font-bold text-xl text-base-content leading-tight transition-colors group-hover/pub:text-primary">
            {title}
          </h3>
          <div class="mt-3 flex flex-col gap-1.5">
            {journal && (
              <div class="flex items-center gap-2 text-[15px] italic font-medium text-base-content/70">
                <i data-lucide="scroll-text" class="w-4 h-4 text-primary/40"></i>
                {journal}
              </div>
            )}
            {conference && (
              <div class="flex items-center gap-2 text-[15px] italic font-medium text-base-content/70">
                <i data-lucide="presentation" class="w-4 h-4 text-primary/40"></i>
                {conference}
              </div>
            )}
          </div>
        </div>
        
        <div class="md:text-right shrink-0">
          <span class="badge badge-primary badge-outline font-bold px-4 py-3 shadow-sm">{date}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .education__time {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    width: 20px;
    shrink: 0;
  }
</style>
