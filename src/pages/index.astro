---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkItem from '../components/WorkItem.astro';
import EducationItem from '../components/EducationItem.astro';
import SkillModule from '../components/SkillModule.astro';
import CertificationItem from '../components/CertificationItem.astro';
import PublicationItem from '../components/PublicationItem.astro';

const name = "Hao Liang";
---

<BaseLayout title={`${name} - AI/ML Engineer`}>
 
 <!-- Home Section -->
 <section id="home" class="content-section">
   <div class="flex flex-col lg:flex-row gap-12 pb-12 mt-5">
     <div class="flex-1">
       <div class="text-xl py-1 font-semibold uppercase tracking-widest text-primary">Hey there 👋</div>
       <div class="text-5xl font-bold py-2 mt-4 leading-tight">I'm Hao Liang 梁昊</div>
       <div class="text-3xl py-3 font-bold opacity-70">AI/ML Engineer</div>
       <div class="py-2 mt-6">
         <p class="text-lg text-justify leading-relaxed">
           Specializing in <b>production LLM systems</b>, cloud-native data platforms, and MLOps for large-scale environments. 
           Experienced in end-to-end system design spanning modeling, optimization, governance, and deployment.
         </p>
       </div>
        <div class="mt-10 flex flex-row flex-wrap items-center gap-3">
          <a href="https://www.linkedin.com/in/hao-liang-75bb32170/" target="_blank" class="btn btn-outline border-indigo-600 text-indigo-600 hover:bg-indigo-600 hover:border-indigo-600 px-6 gap-2">
            <i data-lucide="linkedin" class="w-4 h-4 pointer-events-none"></i>
            LinkedIn
          </a>
          <div class="tooltip tooltip-bottom" data-tip="Click to copy email">
            <button class="btn btn-outline border-indigo-600 text-indigo-600 hover:bg-indigo-600 hover:border-indigo-600 px-6 gap-2 copy-email-btn"> 
              <i data-lucide="mail" class="w-4 h-4 pointer-events-none"></i>
              haoliang428@outlook.com
            </button>
          </div>
          <a href="https://scholar.google.com/citations?user=rM-i678AAAAJ&hl" target="_blank" class="btn btn-outline border-indigo-600 text-indigo-600 hover:bg-indigo-600 hover:border-indigo-600 px-6 gap-2">
            <i data-lucide="graduation-cap" class="w-4 h-4 pointer-events-none"></i>
            Google Scholar
          </a>
        </div>
      </div>
     <!-- Personal Photo -->
     <div class="w-full lg:w-72 shrink-0">
       <div class="rounded-3xl overflow-hidden shadow-2xl border-4 border-white transform lg:rotate-3 hover:rotate-0 transition-transform duration-500">
         <img src="/personal-website/personal_photo.jpg" alt="Hao Liang" class="w-full h-auto object-cover aspect-[3/4]" />
       </div>
     </div>
   </div>

   <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-16">
     <div class="lg:col-span-2">
       <div class="text-3xl w-full font-bold mb-8 border-b-4 border-primary/20 pb-4 inline-block tracking-tight">Core Technical Specializations</div>
       <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
         <!-- Pillar 1 -->
         <div class="glass p-8 rounded-[2.5rem] border border-white/40 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1 group">
           <div class="mb-6 flex items-center justify-start transition-transform group-hover:scale-110 duration-500">
             <i class="devicon-pytorch-original colored text-5xl filter drop-shadow-[0_0_15px_rgba(238,83,59,0.3)]"></i>
           </div>
           <h3 class="text-xl font-extrabold text-slate-900 mb-3 leading-tight tracking-tight">Agentic AI & LLM Systems</h3>
           <p class="text-[13px] text-base-content/70 leading-relaxed font-medium">
             Architecting production-grade knowledge systems and autonomous workflows using RAG pipelines, prompt engineering, and LLM orchestration.
           </p>
         </div>

         <!-- Pillar 2 -->
         <div class="glass p-8 rounded-[2.5rem] border border-white/40 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1 group">
           <div class="mb-6 flex items-center justify-start transition-transform group-hover:scale-110 duration-500">
             <i class="devicon-apachespark-plain colored text-5xl filter drop-shadow-[0_0_15px_rgba(226,98,21,0.3)]"></i>
           </div>
           <h3 class="text-xl font-extrabold text-slate-900 mb-3 leading-tight tracking-tight text-balance">Distributed Data Engineering</h3>
           <p class="text-[13px] text-base-content/70 leading-relaxed font-medium">
             Designing scalable cloud-native architectures and high-throughput ETL/ELT pipelines to manage complex, high-dimensional datasets.
           </p>
         </div>

         <!-- Pillar 3 -->
         <div class="glass p-8 rounded-[2.5rem] border border-white/40 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1 group">
           <div class="mb-6 flex items-center justify-start transition-transform group-hover:scale-110 duration-500">
             <i class="devicon-python-plain colored text-5xl filter drop-shadow-[0_0_15px_rgba(55,118,171,0.3)]"></i>
           </div>
           <h3 class="text-xl font-extrabold text-slate-900 mb-3 leading-tight tracking-tight text-balance">Algorithmic Optimization & Decision Logic</h3>
           <p class="text-[13px] text-base-content/70 leading-relaxed font-medium">
             Translating multi-dimensional constraints into scalable decision-making logic using graph-based algorithms and mathematical optimization frameworks.
           </p>
         </div>

         <!-- Pillar 4 -->
         <div class="glass p-8 rounded-[2.5rem] border border-white/40 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1 group">
           <div class="mb-6 flex items-center justify-start transition-transform group-hover:scale-110 duration-500">
             <i class="devicon-kubernetes-plain colored text-5xl filter drop-shadow-[0_0_15px_rgba(50,109,230,0.3)]"></i>
           </div>
           <h3 class="text-xl font-extrabold text-slate-900 mb-3 leading-tight tracking-tight">Production MLOps & Cloud Infrastructure</h3>
           <p class="text-[13px] text-base-content/70 leading-relaxed font-medium">
             Managing the end-to-end machine learning lifecycle through containerized microservices, Infrastructure as Code, and automated CI/CD pipelines.
           </p>
         </div>

         <!-- Pillar 5 (Wide) -->
         <div class="glass p-8 rounded-[2.5rem] border border-white/40 shadow-sm transition-all hover:shadow-xl hover:-translate-y-1 md:col-span-2 group">
           <div class="flex flex-col md:flex-row gap-8 items-start">
             <div class="transition-transform group-hover:scale-110 duration-500 shrink-0">
               <i class="devicon-jupyter-plain colored text-6xl filter drop-shadow-[0_0_15px_rgba(243,118,38,0.3)]"></i>
             </div>
             <div>
               <h3 class="text-xl font-extrabold text-slate-900 mb-3 leading-tight tracking-tight">Advanced Predictive Modeling</h3>
               <p class="text-[13px] text-base-content/70 leading-relaxed font-medium">
                 Developing statistical and neural architectures for high-fidelity pattern recognition, time-series forecasting, and automated data synthesis.
               </p>
             </div>
           </div>
         </div>
       </div>
     </div>
     <!-- Memes Sidebar -->
     <div class="flex flex-col gap-8">
       <div>
         <div class="text-xl font-bold mb-8 opacity-40 uppercase tracking-widest text-center lg:text-left">Spook Distribution</div>         <div class="card bg-base-100 shadow-lg border border-base-200 overflow-hidden group">
           <figure class="px-4 pt-4">
             <img src="/personal-website/meme.jpg" alt="Statistics Meme" class="rounded-xl grayscale group-hover:grayscale-0 transition-all duration-500" />
           </figure>
           <div class="card-body p-6 items-center text-center">
             <p class="text-xs italic opacity-60">"In God we trust, all others must bring data."</p>
           </div>
         </div>
       </div>

       <div>
         <div class="text-xl font-bold mb-8 opacity-40 uppercase tracking-widest text-center lg:text-left">Developer Reality</div>
         <div class="card bg-base-100 shadow-lg border border-base-200 overflow-hidden group">
           <figure class="px-4 pt-4">
             <img src="/personal-website/git_push_meme.jpg" alt="Git Push Meme" class="rounded-xl grayscale group-hover:grayscale-0 transition-all duration-500" />
           </figure>
           <div class="card-body p-6 items-center text-center">
             <p class="text-xs italic opacity-60">"It works on my machine... but I don't live on my machine."</p>
           </div>
         </div>
       </div>
     </div>   </div>
 </section>
 <!-- Experience Section -->
 <section id="experience" class="content-section hidden">
 <div class="mb-10">
 <div class="text-3xl w-full font-bold mb-12 border-b-4 border-primary/20 pb-4 inline-block tracking-tight">Professional Experience</div>
 
 
 <WorkItem 
 title="Roche"
 subtitle="Data Engineer"
 date="Mar 2024 – Present"
 location="Branchburg, NJ"
 logo="/personal-website/logos/roche.png"
 summary="Design and deliver end-to-end AI/ML, data engineering, and optimization systems supporting Roche’s R&D and product pipelines"
 categories={[
 {
 name: "AI & LLM Engineering and Optimization",
 items: [
 "Architect production-grade LLM knowledge systems by building RAG pipelines and benchmarking NLP models (LDA, BERT, BART) to automate R&D data synthesis",
 "Integrate evaluation frameworks (Ragas) to quantify retrieval accuracy and generation quality, ensuring high-fidelity outputs for sensitive scientific workflows",
 "Build OCR and embedding-based parsing pipelines to convert compliance documents into structured data, automating form-filling and reducing manual effort",
 "Apply graph-based optimization algorithms (e.g., Dijkstra's) to automate combinatorial oligonucleotide design, translating scientific constraints into scalable decision logic",
 "Optimize manufacturing logistics and reduce line failures using Optimization to balance inventory and production targets"
 ]
 },
 {
 name: "Data Architecture and Governance",
 items: [
 "Engineer Data Vault 2.0 on Snowflake, integrating SAP, MES, and SQL Server sources via Qlik, Talend, and dbt to establish a governed, analytics-ready data foundation",
 "Build a data governance stack integrating Monte Carlo, Collibra, and Immuta to enable observability, metadata management, and secure access across AI workloads"
 ]
 },
 {
 name: "Cloud Infrastructure and MLOps",
 items: [
 "Modernize production infrastructure by migrating 10+ projects to AWS ECS/Fargate using GitLab CI/CD and Infrastructure as Code (IaC)"
 ]
 },
 {
 name: "Analytics Platforms & BI Automation",
