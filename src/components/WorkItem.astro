---
interface BulletCategory {
  name: string;
  items: string[];
}

interface Props {
  title: string;
  subtitle: string;
  date: string;
  location: string;
  logo?: string;
  summary?: string;
  bullets?: string[];
  categories?: BulletCategory[];
  lastItem?: boolean;
}

const { title, subtitle, date, location, logo, summary, bullets, categories, lastItem } = Astro.props;
const hasDetails = (bullets && bullets.length > 0) || (categories && categories.length > 0);
---

<div class="flex relative group/item mb-2 last:mb-0">
  <!-- Timeline Line and Node -->
  <div class="education__time w-5 shrink-0 flex flex-col items-center relative">
    <!-- Continuous Line with Fade-out for Last Item -->
    <div class={`absolute top-0 w-[2px] transition-colors duration-300 h-full ${lastItem ? 'bg-gradient-to-b from-primary/20 via-primary/20 to-transparent' : 'bg-primary/20 group-hover/item:bg-primary/50'}`}></div>
    
    <!-- The Dot (Node) -->
    <span class="w-4 h-4 bg-primary block rounded-full mt-10 relative z-10 shadow-lg shadow-primary/40 ring-4 ring-primary/20 transition-all duration-300 group-hover/item:scale-125"></span>
  </div>
  
  <!-- The Individual Glass Block -->
  <div class="education__data bd-grid px-8 pb-10 w-full transition-all duration-300">
    <div class="glass p-8 rounded-[2rem] border border-white/40 shadow-sm group-hover/item:shadow-xl group-hover/item:-translate-y-1 transition-all duration-300">
      <div class="flex flex-col md:flex-row justify-between items-start mb-2 gap-4">
        <div class="flex gap-5 items-start">
          {logo && (
            <div class="w-16 h-16 rounded-2xl bg-white shadow-md border border-base-200 flex items-center justify-center p-2 shrink-0 group-hover/item:shadow-lg transition-all">
              <img src={logo} alt={`${title} logo`} class="max-w-full max-h-full object-contain" />
            </div>
          )}
          <div class="flex flex-col">
            <h3 class="font-bold text-2xl text-base-content leading-tight transition-colors group-hover/item:text-primary">{title}</h3>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1.5">
              <span class="text-primary font-bold text-lg">{subtitle}</span>
            </div>
          </div>
        </div>
        <div class="md:text-right shrink-0 flex flex-col items-start md:items-end gap-2">
          <span class="badge badge-primary badge-outline font-bold px-4 py-3 shadow-sm">{date}</span>
          <span class="text-base-content/60 flex items-center gap-1.5 text-sm font-medium px-1">
            <i data-lucide="map-pin" class="w-3.5 h-3.5 text-primary/60"></i>
            {location}
          </span>
        </div>
      </div>

      {summary && <p class="text-base-content/80 mt-4 text-[0.95rem] leading-relaxed font-medium">{summary}</p>}

      {hasDetails && (
        <div class="mt-5">
          <button class="read-more-btn flex items-center gap-2 px-5 py-2.5 rounded-xl bg-base-200 border border-base-300 text-primary text-xs font-bold uppercase tracking-widest hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 shadow-sm active:scale-95">
            <span class="btn-text">Read more</span>
            <div class="icon-wrapper transition-transform duration-300">
              <i data-lucide="chevron-down" class="w-4 h-4"></i>
            </div>
          </button>
          
          <div class="read-more-content grid [grid-template-rows:0fr] transition-[grid-template-rows] duration-500 ease-in-out">
            <div class="overflow-hidden">
              <div class="pt-6 pb-2">
                {bullets && (
                  <ul class="list-none space-y-3.5">
                    {bullets.map((b) => (
                      <li class="flex gap-4 items-start text-base-content/80 leading-relaxed text-sm group/bullet hover:text-base-content transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary/40 mt-2 shrink-0 group-hover/bullet:bg-primary transition-all duration-300 group-hover/bullet:scale-150 group-hover/bullet:shadow-[0_0_8px_rgba(var(--fallback-p,var(--p)),0.6)]"></span>
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                )}

                {categories && (
                  <div class="space-y-6">
                    {categories.map((cat) => (
                      <div class="bg-base-200/40 p-6 rounded-2xl border border-base-200 hover:border-primary/30 transition-colors shadow-sm">
                        <h4 class="text-xs font-black uppercase tracking-[0.15em] text-primary mb-4 flex items-center gap-2">
                          <i data-lucide="layers" class="w-4 h-4"></i>
                          {cat.name}
                        </h4>
                        <ul class="list-none space-y-3.5">
                          {cat.items.map((item) => (
                            <li class="flex gap-4 items-start text-base-content/80 leading-relaxed text-sm group/bullet hover:text-base-content transition-colors">
                              <span class="w-1.5 h-1.5 rounded-full bg-primary/40 mt-2 shrink-0 group-hover/bullet:bg-primary transition-all duration-300 group-hover/bullet:scale-150 group-hover/bullet:shadow-[0_0_8px_rgba(var(--fallback-p,var(--p)),0.6)]"></span>
                              <span>{item}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .read-more-content.is-open {
    grid-template-rows: 1fr;
  }
</style>

<script>
  function initReadMore() {
    const btns = document.querySelectorAll('.read-more-btn');
    btns.forEach((btn) => {
      if(btn.hasAttribute('data-bound')) return;
      btn.setAttribute('data-bound', 'true');
      
      btn.addEventListener('click', () => {
        const content = btn.nextElementSibling;
        if (!content) return;
        
        const iconWrapper = btn.querySelector('.icon-wrapper');
        const text = btn.querySelector('.btn-text');
        
        const isOpen = content.classList.contains('is-open');
        if (isOpen) {
          content.classList.remove('is-open');
          if(iconWrapper) (iconWrapper as HTMLElement).style.transform = 'rotate(0deg)';
          if(text) text.textContent = 'Read more';
        } else {
          content.classList.add('is-open');
          if(iconWrapper) (iconWrapper as HTMLElement).style.transform = 'rotate(180deg)';
          if(text) text.textContent = 'Show less';
        }
      });
    });
  }

  initReadMore();
  document.addEventListener('astro:after-swap', initReadMore);
</script>
