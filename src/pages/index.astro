        />
        <PublicationItem 
          title="The Forecast Ability of a Belief-Based Momentum Indicator in Full-Day, Daytime, and Nighttime Volatilities of Chinese Oil Futures"
          authors="Li, Y., Huynh, L., Xu, Y., & Liang, H."
          journal="Energy Economics"
          date="2023"
        />
      </div>

      <!-- Journal Reviewer Section (Single Column) -->
      <div class="mb-16">
        <div class="text-xl font-bold mb-8 opacity-40 uppercase tracking-[0.2em] flex items-center gap-3">
          <i data-lucide="check-circle-2" class="w-5 h-5"></i>
          Journal Peer Reviewer
        </div>
        <div class="glass p-10 rounded-[2.5rem] border border-white/40 shadow-sm">
          <div class="flex flex-col gap-y-6">
            {[
              "Journal of Innovation & Knowledge",
              "Finance Research Letters",
              "International Review of Financial Analysis",
              "Research in International Business and Finance",
              "International Review of Economics and Finance",
              "Evaluation Review",
              "International Finance",
              "Review of Accounting and Finance",
              "Humanities and Social Sciences Communications"
            ].map((journal) => (
              <div class="flex items-center gap-4 group/journal transition-all">
                <div class="w-8 h-8 rounded-full bg-primary/5 flex items-center justify-center text-primary group-hover/journal:bg-primary group-hover/journal:text-white transition-all duration-300">
                  <i data-lucide="check" class="w-4 h-4"></i>
                </div>
                <span class="text-[15px] font-medium text-base-content/80 group-hover/journal:text-primary transition-colors">{journal}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Research Experiences -->
      <div class="space-y-4">
        <div class="text-xl font-bold mb-8 opacity-40 uppercase tracking-[0.2em] flex items-center gap-3">
