---
const menuItems = [
	{ id: 'summary', label: 'Summary', icon: 'user' },
	{ id: 'experience', label: 'Experience', icon: 'briefcase' },
	{ id: 'education', label: 'Education', icon: 'graduation-cap' },
	{ id: 'research', label: 'Research', icon: 'microscope' },
	{ id: 'publications', label: 'Publications', icon: 'book-open' },
	{ id: 'skills', label: 'Skills', icon: 'code-2' },
	{ id: 'certifications', label: 'Certifications', icon: 'award' },
	{ id: 'service', label: 'Service', icon: 'heart' }
];

interface Props {
	name: string;
	email: string;
	linkedin: string;
	scholar: string;
}

const { name, email, linkedin, scholar } = Astro.props;
---

<aside class="w-full lg:w-80 order-1 lg:order-2 shrink-0">
	<div class="lg:sticky lg:top-12 space-y-6">
		<!-- Profile Card -->
		<div class="glass rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-white/40">
			<div class="relative mb-6">
				<div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-indigo-500 to-blue-600 flex items-center justify-center text-white shadow-lg shadow-blue-200">
					<span class="text-3xl font-bold">HL</span>
				</div>
				<div class="absolute -bottom-1 -right-1 w-6 h-6 bg-green-500 border-4 border-white rounded-full"></div>
			</div>
			
			<h1 class="text-2xl font-bold tracking-tight text-slate-900 mb-1">{name}</h1>
			<p class="text-indigo-600 font-semibold text-sm mb-6 uppercase tracking-wider">AI/ML Engineer</p>
			
			<div class="space-y-3 mb-8">
				<a href={`mailto:${email}`} class="flex items-center gap-3 p-2.5 rounded-xl hover:bg-white/50 transition-colors text-sm group border border-transparent hover:border-slate-100">
					<div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all">
						<i data-lucide="mail" class="w-4 h-4"></i>
					</div>
					<span class="text-slate-600 font-medium truncate">{email}</span>
				</a>
				<a href={linkedin} target="_blank" class="flex items-center gap-3 p-2.5 rounded-xl hover:bg-white/50 transition-colors text-sm group border border-transparent hover:border-slate-100">
					<div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all">
						<i data-lucide="linkedin" class="w-4 h-4"></i>
					</div>
					<span class="text-slate-600 font-medium">LinkedIn</span>
				</a>
				<a href={scholar} target="_blank" class="flex items-center gap-3 p-2.5 rounded-xl hover:bg-white/50 transition-colors text-sm group border border-transparent hover:border-slate-100">
					<div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all">
						<i data-lucide="graduation-cap" class="w-4 h-4"></i>
					</div>
					<span class="text-slate-600 font-medium">Google Scholar</span>
				</a>
			</div>

			<nav class="space-y-1.5">
				{menuItems.map((item) => (
					<button 
						data-section-btn={item.id}
						class="w-full flex items-center gap-3 px-4 py-3 text-sm font-semibold text-slate-500 rounded-xl hover:bg-white hover:shadow-sm hover:text-indigo-600 transition-all text-left group section-btn border border-transparent"
					>
						<i data-lucide={item.icon} class="w-4 h-4 transition-transform group-hover:scale-110 shrink-0"></i>
						{item.label}
					</button>
				))}
			</nav>
		</div>

		<!-- Footer/Status Card -->
		<div class="glass rounded-2xl p-6 border border-white/40 shadow-sm">
			<div class="flex items-center gap-3 text-sm font-medium text-slate-500">
				<span class="relative flex h-2 w-2">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
				</span>
				Available for Opportunities
			</div>
		</div>
	</div>
</aside>

<script>
	const buttons = document.querySelectorAll('.section-btn');
	const sections = document.querySelectorAll('.content-section');

	function setActiveSection(id: string) {
		buttons.forEach(btn => {
			if (btn.getAttribute('data-section-btn') === id) {
				btn.classList.add('bg-white', 'text-indigo-600', 'shadow-sm', 'border-slate-100');
				btn.classList.remove('text-slate-500');
			} else {
				btn.classList.remove('bg-white', 'text-indigo-600', 'shadow-sm', 'border-slate-100');
				btn.classList.add('text-slate-500');
			}
		});

		sections.forEach(section => {
			if (section.id === id) {
				section.classList.remove('hidden');
				section.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-2', 'duration-500');
			} else {
				section.classList.add('hidden');
			}
		});
		
		// @ts-ignore
		if (window.lucide) {
			// @ts-ignore
			window.lucide.createIcons();
		}
	}

	buttons.forEach(btn => {
		btn.addEventListener('click', () => {
			const id = btn.getAttribute('data-section-btn');
			if (id) setActiveSection(id);
		});
	});

	// Default section
	setActiveSection('summary');
</script>
