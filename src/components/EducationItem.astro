---
interface Props {
  school: string;
  degree: string;
  date: string;
  location: string;
  logo?: string;
  gpa?: string;
  honors?: string;
  lastItem?: boolean;
}

const { school, degree, date, location, logo, gpa, honors, lastItem } = Astro.props;
---

<div class="flex relative group/edu mb-2 last:mb-0">
  <div class="education__time w-5 shrink-0 flex flex-col items-center relative">
    <div class={`absolute top-0 w-[2px] transition-colors duration-300 h-full ${lastItem ? 'bg-gradient-to-b from-primary/20 via-primary/20 to-transparent' : 'bg-primary/20 group-hover/edu:bg-primary/50'}`}></div>
    <span class="w-4 h-4 bg-primary block rounded-full mt-10 relative z-10 shadow-lg shadow-primary/40 ring-4 ring-primary/20 transition-all duration-300 group-hover/edu:scale-125"></span>
  </div>
  
  <div class="education__data bd-grid px-8 pb-10 w-full transition-all duration-300">
    <div class="glass p-8 rounded-[2rem] border border-white/40 shadow-sm group-hover/edu:shadow-xl group-hover/edu:-translate-y-1 transition-all duration-300">
      <div class="flex flex-col md:flex-row justify-between items-start mb-2 gap-4">
        <div class="flex gap-5 items-start">
          {logo && (
            <div class="w-16 h-16 rounded-2xl bg-white shadow-md border border-base-200 flex items-center justify-center p-2 shrink-0 group-hover/edu:shadow-lg transition-all">
              <img src={logo} alt={`${school} logo`} class="max-w-full max-h-full object-contain" />
            </div>
          )}
          <div class="flex flex-col">
            <h3 class="font-bold text-2xl text-base-content leading-tight transition-colors group-hover/edu:text-primary">{school}</h3>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1.5">
              <span class="text-primary font-bold text-lg">{degree}</span>
            </div>
          </div>
        </div>
        <div class="md:text-right shrink-0 flex flex-col items-start md:items-end gap-2 mt-2 md:mt-0">
          <span class="badge badge-primary badge-outline font-bold px-4 py-3 shadow-sm">{date}</span>
          <span class="text-base-content/60 flex items-center gap-1.5 text-sm font-medium px-1">
            <i data-lucide="map-pin" class="w-3.5 h-3.5 text-primary/60"></i>
            {location}
          </span>
        </div>
      </div>

      {(gpa || honors) && (
        <div class="mt-4 flex flex-wrap gap-3 text-sm font-semibold">
          {gpa && (
            <div class="flex items-center gap-2 px-4 py-2 bg-primary/5 text-primary rounded-2xl border border-primary/10 hover:bg-primary/10 transition-colors">
              <i data-lucide="award" class="w-4 h-4"></i>
              GPA: {gpa}
            </div>
          )}
          {honors && (
            <div class="flex items-center gap-2 px-4 py-2 bg-amber-50 text-amber-700 rounded-2xl border border-amber-100 hover:bg-amber-100 transition-colors">
              <i data-lucide="star" class="w-4 h-4"></i>
              {honors}
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .education__time {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    width: 20px;
    shrink: 0;
  }
</style>
